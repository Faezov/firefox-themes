{
  "manifest_version": 2,
  "name": "Dark Forest Rain Bulat Theme",
  "version": "0.4.0",
  "description": "5000x200 animated dark forest rain Firefox theme. Realistic rain, no white margins.",
  "browser_specific_settings": {
    "gecko": {
      "id": "dark-forest-rain-bulat@bulat",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "theme": {
    "images": {
      "theme_frame": "images/dark_forest_rain_5000x200.svg"
    },
    "colors": {
      "frame": "rgba(2, 8, 13, 0.10)",
      "frame_inactive": "rgba(2, 8, 13, 0.38)",
      "toolbar": "rgba(3, 11, 18, 0.08)",
      "toolbar_text": "rgba(236, 253, 255, 0.96)",
      "tab_background_text": "rgba(226, 249, 255, 0.92)",
      "tab_text": "rgba(255, 255, 255, 0.98)",
      "toolbar_field": "rgba(3, 13, 21, 0.26)",
      "toolbar_field_text": "rgba(255, 255, 255, 0.94)",
      "toolbar_field_text_focus": "rgba(255, 255, 255, 1)",
      "toolbar_field_border": "rgba(125, 231, 255, 0.32)",
      "toolbar_field_border_focus": "rgba(160, 242, 255, 0.72)",
      "toolbar_top_separator": "rgba(150, 238, 255, 0.16)",
      "toolbar_bottom_separator": "rgba(78, 201, 228, 0.18)",
      "ntp_background": "rgba(2, 8, 13, 0.96)",
      "bookmark_text": "rgba(235, 253, 255, 0.94)",
      "icons": "rgba(238, 253, 255, 0.96)",
      "icons_attention": "#7bf4ff",
      "button_background_hover": "rgba(142, 235, 255, 0.14)",
      "button_background_active": "rgba(142, 235, 255, 0.22)",
      "popup": "#07131c",
      "popup_text": "#effcff",
      "popup_border": "#25596c",
      "popup_highlight": "#125973",
      "popup_highlight_text": "#ffffff",
      "sidebar": "#07131c",
      "sidebar_text": "#effcff"
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark"
    }
  }
}
