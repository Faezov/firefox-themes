{
  "manifest_version": 2,
  "name": "Southern Cross Night Bulat Theme",
  "version": "0.1.0",
  "description": "Animated southern night sky Firefox theme with a bright Southern Cross, soft rain, and a dark forest horizon.",
  "browser_specific_settings": {
    "gecko": {
      "id": "southern-cross-night-bulat@bulat",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "theme": {
    "images": {
      "theme_frame": "images/southern_cross_night_5000x200.svg"
    },
    "colors": {
      "frame": "rgba(1, 7, 15, 0.14)",
      "frame_inactive": "rgba(1, 7, 15, 0.46)",
      "toolbar": "rgba(3, 10, 20, 0.10)",
      "toolbar_text": "rgba(236, 249, 255, 0.97)",
      "tab_background_text": "rgba(213, 234, 246, 0.93)",
      "tab_text": "rgba(255, 255, 255, 0.98)",
      "toolbar_field": "rgba(2, 12, 24, 0.30)",
      "toolbar_field_text": "rgba(255, 255, 255, 0.95)",
      "toolbar_field_text_focus": "rgba(255, 255, 255, 1)",
      "toolbar_field_border": "rgba(150, 220, 255, 0.34)",
      "toolbar_field_border_focus": "rgba(190, 237, 255, 0.76)",
      "toolbar_top_separator": "rgba(170, 230, 255, 0.16)",
      "toolbar_bottom_separator": "rgba(92, 178, 216, 0.20)",
      "ntp_background": "rgba(1, 7, 15, 0.97)",
      "bookmark_text": "rgba(229, 246, 255, 0.94)",
      "icons": "rgba(238, 250, 255, 0.96)",
      "icons_attention": "#9be7ff",
      "button_background_hover": "rgba(150, 220, 255, 0.14)",
      "button_background_active": "rgba(150, 220, 255, 0.23)",
      "popup": "#07111e",
      "popup_text": "#eefaff",
      "popup_border": "#2b5770",
      "popup_highlight": "#195472",
      "popup_highlight_text": "#ffffff",
      "sidebar": "#07111e",
      "sidebar_text": "#eefaff"
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark"
    }
  }
}
