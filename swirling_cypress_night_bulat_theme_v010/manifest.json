{
  "manifest_version": 2,
  "name": "Swirling Cypress Night Bulat Theme",
  "version": "0.1.0",
  "description": "Animated post-impressionist Firefox theme with cobalt sky swirls, golden starbursts, cypress silhouettes, and warm wheat-field strokes.",
  "browser_specific_settings": {
    "gecko": {
      "id": "swirling-cypress-night-bulat@bulat",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "theme": {
    "images": {
      "theme_frame": "images/swirling_cypress_night_5000x200.svg"
    },
    "colors": {
      "frame": "rgba(4, 12, 33, 0.18)",
      "frame_inactive": "rgba(4, 12, 33, 0.48)",
      "toolbar": "rgba(5, 15, 40, 0.14)",
      "toolbar_text": "rgba(255, 246, 207, 0.98)",
      "tab_background_text": "rgba(224, 233, 255, 0.94)",
      "tab_text": "rgba(255, 255, 255, 0.98)",
      "toolbar_field": "rgba(4, 13, 36, 0.34)",
      "toolbar_field_text": "rgba(255, 249, 224, 0.96)",
      "toolbar_field_text_focus": "rgba(255, 253, 239, 1)",
      "toolbar_field_border": "rgba(255, 211, 91, 0.40)",
      "toolbar_field_border_focus": "rgba(255, 233, 129, 0.82)",
      "toolbar_top_separator": "rgba(255, 228, 117, 0.17)",
      "toolbar_bottom_separator": "rgba(63, 126, 205, 0.24)",
      "ntp_background": "rgba(3, 9, 27, 0.98)",
      "bookmark_text": "rgba(255, 241, 204, 0.95)",
      "icons": "rgba(255, 246, 210, 0.97)",
      "icons_attention": "#ffe36d",
      "button_background_hover": "rgba(255, 211, 91, 0.17)",
      "button_background_active": "rgba(255, 211, 91, 0.27)",
      "popup": "#07112d",
      "popup_text": "#fff4ce",
      "popup_border": "#786121",
      "popup_highlight": "#23579b",
      "popup_highlight_text": "#ffffff",
      "sidebar": "#07112d",
      "sidebar_text": "#fff4ce"
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark"
    }
  }
}
